# 旁路由最小配置 - 只包含灰色网易云、蒲公英、PassWall2
# Root filesystem images
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=500

#============================== IPv6 支持 ==============================#
CONFIG_IPV6=y
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_kmod-ipv6=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_6in4=y
CONFIG_PACKAGE_6to4=y
CONFIG_PACKAGE_6rd=y
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_luci-proto-relay=y

#============================== 基础网络配置 ==============================#
# 旁路由模式 - 仅保留必要的网络功能
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-accesscontrol=y
CONFIG_PACKAGE_luci-app-ddns=y

#============================== 核心插件 ==============================#
# 1. 灰色网易云 (UnblockNeteaseMusic)
CONFIG_PACKAGE_luci-app-unblockmusic=y
CONFIG_PACKAGE_luci-app-unblockmusic_INCLUDE_UnblockNeteaseMusic_Go=y

# 2. 蒲公英VPN (Oray OpenVPN)
CONFIG_PACKAGE_luci-app-pgyvpn=y
# CONFIG_PACKAGE_luci-app-smartdns is not set
# CONFIG_PACKAGE_luci-app-wol is not set

# 3. PassWall2 (Shadowsocks + V2Ray + Trojan + Xray + Hysteria) + 完整依赖
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_ShadowsocksR_Plus=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Plus=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Libev=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_V2ray=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_V2ray_Plugin=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Trojan_Plus=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Xray=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Xray_Plugin=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Hysteria=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_NaiveProxy=y
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_TUIC=y

# PassWall2 核心依赖 - Shadowsocks
CONFIG_PACKAGE_shadowsocks-libev=y
CONFIG_PACKAGE_shadowsocks-libev-ss-local=y
CONFIG_PACKAGE_shadowsocks-libev-ss-redir=y
CONFIG_PACKAGE_shadowsocks-libev-ss-tunnel=y
CONFIG_PACKAGE_shadowsocksr-libev=y

# PassWall2 核心依赖 - V2Ray
CONFIG_PACKAGE_v2ray-core=y
CONFIG_PACKAGE_v2ray-geoip=y
CONFIG_PACKAGE_v2ray-geosite=y

# PassWall2 核心依赖 - Trojan
CONFIG_PACKAGE_trojan-plus=y

# PassWall2 核心依赖 - 其他代理工具
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_hysteria=y
CONFIG_PACKAGE_naiveproxy=y
CONFIG_PACKAGE_tuic=y

# PassWall2 基础依赖库
CONFIG_PACKAGE_libcurl=y
CONFIG_PACKAGE_libopenssl=y
CONFIG_PACKAGE_libevent2=y
CONFIG_PACKAGE_libev=y
CONFIG_PACKAGE_libmbedtls=y
CONFIG_PACKAGE_libsodium=y
CONFIG_PACKAGE_libpcre=y
CONFIG_PACKAGE_zlib=y
CONFIG_PACKAGE_libgo=y

# PassWall2 额外工具
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_resolveip=y

#============================== 基础工具 ==============================#
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-filetransfer=y

#============================== 主题 ==============================#
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# Lang Support
CONFIG_LUCI_LANG_en=y
CONFIG_LUCI_LANG_zh-cn=y
CONFIG_LUCI_LANG_zh-tw=y

#============================== 禁用不需要的插件 ==============================#
# CONFIG_PACKAGE_luci-app-openclash is not set
# CONFIG_PACKAGE_luci-app-store is not set
# CONFIG_PACKAGE_luci-app-autoreboot is not set
# CONFIG_PACKAGE_luci-app-docker is not set
# CONFIG_PACKAGE_luci-app-dockerman is not set
# CONFIG_PACKAGE_luci-app-helloworld is not set
# CONFIG_PACKAGE_luci-app-ssr-plus is not set
# CONFIG_PACKAGE_luci-app-turboacc is not set
# CONFIG_PACKAGE_luci-app-netdata is not set
# CONFIG_PACKAGE_luci-app-onliner is not set
# CONFIG_PACKAGE_luci-app-vlmcsd is not set
# CONFIG_PACKAGE_luci-app-arpbind is not set
# CONFIG_PACKAGE_luci-app-upnp is not set
# CONFIG_PACKAGE_luci-app-vsftpd is not set
# CONFIG_PACKAGE_autosamba is not set
# CONFIG_PACKAGE_kmod-oaf is not set
